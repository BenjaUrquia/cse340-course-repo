<%- include('partials/header') %>

<main>
    <h1><%= category.name %></h1>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
            </li>
        <% }) %>
    </ul>
    
    <% if (user && user.role_name === 'admin') { %>
        <ul>
            <li>
                <a class="btn" href="/edit-category/<%= category.category_id %>">Edit</a>
            </li>
        </ul>
    <% } %>
</main>

<%- include('partials/footer') %>