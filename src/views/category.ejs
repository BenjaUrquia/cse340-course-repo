<%- include('partials/header') %>

<main>
    <h1><%= category.name %></h1>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
            </li>
        <% }) %>
    </ul>

    <a href="/edit-category/<%= category.category_id %>">
        Edit
    </a>

</main>

<%- include('partials/footer') %>